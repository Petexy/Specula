#: src/pm-window.c:1070
msgid "Press Connect to find your phone automatically."
msgstr "Naciśnij Połącz, aby automatycznie znaleźć telefon."

#: src/pm-window.c:1078
msgid "Searching…"
msgstr "Wyszukiwanie…"

#: src/pm-window.c:1080
msgid "Looking for your phone on the local network."
msgstr "Wyszukiwanie telefonu w sieci lokalnej."

#: src/pm-window.c:1088
msgid "Connecting…"
msgstr "Łączenie…"

#: src/pm-window.c:1090
msgid "Starting the mirror server on your device."
msgstr "Uruchamianie serwera kopii lustrzanej na urządzeniu."

#: src/pm-window.c:1110
msgid "Connection failed"
msgstr "Połączenie nie powiodło się"

#: src/pm-window.c:1112
msgid "Could not reach the device."
msgstr "Nie można połączyć się z urządzeniem."

#: src/pm-window.c:1651 src/pm-window.c:1664 src/pm-connect-dialog.c:79
msgid "Lockscreen PIN"
msgstr "PIN ekranu blokady"

#: src/pm-window.c:1658 src/pm-connect-dialog.c:72
msgid "Auto-unlock"
msgstr "Automatyczne odblokowanie"

#: src/pm-window.c:1660
msgid ""
"Stored encrypted on this computer, tied to this phone, and used to unlock it "
"automatically when it connects."
msgstr ""
"Przechowywany w postaci zaszyfrowanej na tym komputerze, powiązany z tym "
"telefonem i używany do automatycznego odblokowywania go przy połączeniu."

