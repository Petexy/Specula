msgstr "锁屏 PIN(_L)…"

#: src/pm-window.c:3783
msgid "_First Time Setup"
msgstr "首次设置(_F)"

#: src/pm-window.c:3789
msgid "_Manual Connection…"
msgstr "手动连接(_M)…"

#: src/pm-window.c:3790
msgid "_Set Up Device…"
msgstr "设置设备(_S)…"

#: src/pm-window.c:3796
msgid "_Settings"
msgstr "设置(_S)"

#: src/pm-window.c:3797
msgid "_About Phone Mirror"
msgstr "关于手机镜像(_A)"

#: src/pm-window.c:3802
msgid "_Quit"
msgstr "退出(_Q)"

#: src/pm-window.c:3886
msgid "Keep controls visible"
msgstr "保持控件可见"

#: src/pm-window.c:3901
msgid "Press Connect to look for your paired device."
msgstr "按“连接”查找已配对的设备。"

#: src/pm-window.c:3906
msgid "Connect"
msgstr "连接"

#: src/pm-window.c:3913
msgid "Set Up Device…"
msgstr "设置设备…"

#: src/pm-connect-dialog.c:74
msgid ""
"OPTIONAL. Stored encrypted on this computer, keyed to the phone, and used to "
"unlock its lockscreen automatically on connect. Otherwise, the app will show "
"a black screen during unlocking phone."
msgstr "可选。以加密形式存储在此计算机上,与手机绑定,用于在连接时自动解锁其锁屏。否则,应用在解锁手机期间将显示黑屏。"

#: src/pm-connect-dialog.c:104
msgid "Enter the device IP address"
msgstr "输入设备 IP 地址"

#: src/pm-connect-dialog.c:176
msgid "Enter pairing address (ip:port) and code"
msgstr "输入配对地址(ip:端口)和配对码"

#: src/pm-connect-dialog.c:185
msgid "Invalid pairing port"
msgstr "配对端口无效"

#: src/pm-connect-dialog.c:193
msgid "Pairing…"
msgstr "正在配对…"

#: src/pm-connect-dialog.c:240
msgid "Android 11+: enable Wireless debugging → Pair device with code."
msgstr "Android 11+:启用无线调试 → 使用配对码配对设备。"

#: src/pm-connect-dialog.c:266
msgid "Connection"
msgstr "连接"

#: src/pm-connect-dialog.c:268
msgid ""
"Enter the Wi-Fi debugging address only if automatic discovery cannot find "
"the phone."
msgstr "仅当自动发现无法找到手机时,才输入 Wi-Fi 调试地址。"

#: src/pm-connect-dialog.c:271
msgid "IP address"
msgstr "IP 地址"

#: src/pm-connect-dialog.c:273
msgid "Port (default 5555)"
msgstr "端口(默认 5555)"

#: src/pm-connect-dialog.c:283
msgid "Connect manually"
msgstr "手动连接"

#: src/pm-connect-dialog.c:296
msgid "Manual connection"
msgstr "手动连接"

#: src/pm-settings-dialog.c:86
msgid "Display"
msgstr "显示"

#: src/pm-settings-dialog.c:88
msgid "Mirror"
msgstr "镜像"

#: src/pm-settings-dialog.c:88
msgid "Virtual"
msgstr "虚拟"

#: src/pm-settings-dialog.c:91
msgid "Display mode"
msgstr "显示模式"

#: src/pm-settings-dialog.c:93
msgid ""
"Mirror the phone's screen, or run a separate virtual display on the device."
msgstr "镜像手机屏幕,或在设备上运行单独的虚拟显示器。"

#: src/pm-settings-dialog.c:101
msgid "Width"
msgstr "宽度"

#: src/pm-settings-dialog.c:103
msgid "Virtual display width in pixels."
msgstr "虚拟显示器的宽度(像素)。"

#: src/pm-settings-dialog.c:107
msgid "Height"
msgstr "高度"

#: src/pm-settings-dialog.c:109
msgid "Virtual display height in pixels."
msgstr "虚拟显示器的高度(像素)。"

#: src/pm-settings-dialog.c:113
msgid "Density (DPI)"
msgstr "密度(DPI)"

#: src/pm-settings-dialog.c:115
msgid "Pixel density of the virtual display."
msgstr "虚拟显示器的像素密度。"

#: src/pm-settings-dialog.c:122
msgid "Video bitrate (Mbps)"
msgstr "视频比特率(Mbps)"

#: src/pm-settings-dialog.c:124
msgid "Lower it to save bandwidth. Reconnects to apply."
msgstr "降低它以节省带宽。重新连接后生效。"

#: src/pm-settings-dialog.c:132
msgid "Turn off phone screen"
msgstr "关闭手机屏幕"

#: src/pm-settings-dialog.c:134
msgid ""
"Dark the phone's panel to save battery once you unlock it. Reconnects to "
"apply."
msgstr "解锁后熄灭手机面板以节省电量。重新连接后生效。"

#: src/pm-settings-dialog.c:138
msgid "Window"
msgstr "窗口"

#: src/pm-settings-dialog.c:142
msgid "Free resize"
msgstr "自由调整大小"

#: src/pm-settings-dialog.c:144
msgid "Resize the window freely instead of keeping the phone's aspect ratio."
msgstr "自由调整窗口大小,而不保持手机的宽高比。"

#: src/pm-settings-dialog.c:148
msgid "Input"
msgstr "输入"

#: src/pm-settings-dialog.c:150
msgid "Mouse"
msgstr "鼠标"

#: src/pm-settings-dialog.c:150
msgid "Touch"
msgstr "触摸"

#: src/pm-settings-dialog.c:153
msgid "Pointer input"
msgstr "指针输入"

#: src/pm-settings-dialog.c:155
msgid "How mouse input is sent to the phone."
msgstr "如何将鼠标输入发送到手机。"

#: src/pm-settings-dialog.c:161
msgid "Audio"
msgstr "音频"

#: src/pm-settings-dialog.c:165
msgid "Play phone audio"
msgstr "播放手机音频"

#: src/pm-settings-dialog.c:167
msgid "Route the phone's sound to this computer. Reconnects to apply."
msgstr "将手机的声音路由到此计算机。重新连接后生效。"

#: src/pm-session.c:186
msgid "Mirroring a connected phone"
msgstr "正在镜像已连接的手机"

#: src/pm-session.c:371
#, c-format
msgid "scrcpy-server exited with status %d"
msgstr "scrcpy-server 已退出,状态为 %d"

#: src/pm-session.c:399
#, c-format
msgid "timed out waiting for scrcpy-server socket%s%s"
msgstr "等待 scrcpy-server 套接字超时%s%s"

#: src/pm-session.c:646
msgid "Connecting to device…"
msgstr "正在连接到设备…"

#: src/pm-session.c:653
msgid ""
"Could not find scrcpy-server. Install scrcpy or set PM_SERVER_JAR to the "
"server path."
msgstr "找不到 scrcpy-server。请安装 scrcpy,或将 PM_SERVER_JAR 设置为服务器路径。"

#: src/pm-session.c:660
msgid ""
"Could not determine scrcpy-server version. Install scrcpy or set "
"PM_SCRCPY_VERSION to match your server."
msgstr "无法确定 scrcpy-server 的版本。请安装 scrcpy,或将 PM_SCRCPY_VERSION 设置为与您的服务器匹配。"

#: src/pm-session.c:718
msgid "Connecting with adb…"
msgstr "正在通过 adb 连接…"

#: src/pm-session.c:734
msgid "Installing mirror server…"
msgstr "正在安装镜像服务器…"

#: src/pm-session.c:740
msgid "Opening mirror socket…"
msgstr "正在打开镜像套接字…"

#: src/pm-session.c:746
msgid "Starting mirror server…"
msgstr "正在启动镜像服务器…"

#: src/pm-session.c:753
msgid "Connecting video stream…"
msgstr "正在连接视频流…"

#: src/pm-session.c:764
msgid "Connecting audio stream…"
msgstr "正在连接音频流…"

#: src/pm-session.c:771
msgid "Connecting controls…"
msgstr "正在连接控制…"

#: src/pm-session.c:782
msgid "Reading video stream…"
msgstr "正在读取视频流…"

#: src/pm-session.c:929
#, c-format
msgid "%s failed: %s%s"
msgstr "%s 失败:%s%s"

#: src/pm-session.c:931
msgid "connection failed"
msgstr "连接失败"

#: src/pm-session.c:994
msgid "Found device — starting mirror server…"
msgstr "已找到设备 — 正在启动镜像服务器…"

#: src/pm-session.c:1063
msgid ""
"No phone found. Use Set Up Device to enter your phone's Wireless debugging "
"address."
msgstr "未找到手机。请使用“设置设备”输入手机的无线调试地址。"
