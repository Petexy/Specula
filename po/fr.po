#: src/pm-session.c:793
msgid ""
"Could not find scrcpy-server. Install scrcpy or set PM_SERVER_JAR to the "
"server path."
msgstr ""
"Impossible de trouver scrcpy-server. Installez scrcpy ou définissez "
"PM_SERVER_JAR sur le chemin du serveur."

#: src/pm-session.c:800
msgid ""
"Could not determine scrcpy-server version. Install scrcpy or set "
