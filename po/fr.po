msgstr "Impossible de déterminer la version de scrcpy-server. Installez scrcpy ou définissez PM_SCRCPY_VERSION pour correspondre à votre serveur."

#: src/pm-session.c:718
msgid "Connecting with adb…"
msgstr "Connexion avec adb…"

#: src/pm-session.c:734
