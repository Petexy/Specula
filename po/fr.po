msgid "Phone Mirror"
msgstr "Miroir du téléphone"

#: src/pm-window.c:1154 src/pm-window.c:1214 src/pm-session.c:1229
msgid "No phone found"
msgstr "Aucun téléphone trouvé"

#: src/pm-window.c:1173
msgid "Press Connect to find your phone automatically."
msgstr "Appuyez sur Connecter pour trouver votre téléphone automatiquement."

#: src/pm-window.c:1181
msgid "Searching…"
msgstr "Recherche…"

#: src/pm-window.c:1183
msgid "Looking for your phone on the local network."
msgstr "Recherche de votre téléphone sur le réseau local."

#: src/pm-window.c:1191
msgid "Connecting…"
msgstr "Connexion…"

#: src/pm-window.c:1193
msgid "Starting the mirror server on your device."
msgstr "Démarrage du serveur de recopie sur votre appareil."

#: src/pm-window.c:1214
msgid "Connection failed"
msgstr "Échec de la connexion"

#: src/pm-window.c:1217
msgid ""
"Make sure Wireless ADB is turned on on your phone. Android turns it off "
"every time the phone loses its Wi-Fi connection."
msgstr ""
"Assurez-vous que l'ADB sans fil est activé sur votre téléphone. Android le "
"désactive chaque fois que le téléphone perd sa connexion Wi-Fi."

#: src/pm-window.c:1219
msgid "Could not reach the device."
msgstr "Impossible de joindre l'appareil."

#: src/pm-window.c:1454 src/pm-window.c:1522
msgid "Incorrect PIN"
msgstr "Code PIN incorrect"

#: src/pm-window.c:1454
msgid "Unlock Phone"
msgstr "Déverrouiller le téléphone"

#: src/pm-window.c:1455
msgid "Try again."
msgstr "Réessayez."

#: src/pm-window.c:1455
msgid "Enter your PIN."
msgstr "Saisissez votre code PIN."

#: src/pm-window.c:1459
msgid "PIN"
msgstr "PIN"

#: src/pm-window.c:1465 src/pm-window.c:3004
msgid "Cancel"
msgstr "Annuler"

#. Floating Unlock button: an accent pill riding over the bottom of the mirror,
#. * shown only while the phone is on its lockscreen (driven by the session's
#. * keyguard poll). Tapping it opens the one-time PIN dialog. A revealer
#. * crossfades it in/out, mirroring the auto-unlock alert above. Uses the same
#. * pill + suggested-action style as the app's other primary actions.
#: src/pm-window.c:1466 src/pm-window.c:4395
msgid "Unlock"
msgstr "Déverrouiller"

#: src/pm-window.c:1523
msgid ""
"The saved lockscreen PIN didn't unlock your phone. Auto-unlock has stopped "
"trying so repeated wrong attempts can't lock you out of the device. Enter "
"the correct PIN to try again."
msgstr ""
"Le code PIN d'écran de verrouillage enregistré n'a pas déverrouillé votre "
"téléphone. Le déverrouillage automatique a cessé d'essayer afin que des "
"tentatives erronées répétées ne vous bloquent pas l'accès à l'appareil. "
"Saisissez le bon code PIN pour réessayer."

#: src/pm-window.c:1528
msgid "Dismiss"
msgstr "Ignorer"

#: src/pm-window.c:1529
msgid "Enter PIN"
msgstr "Saisir le code PIN"

#: src/pm-window.c:2012 src/pm-window.c:2025 src/pm-connect-dialog.c:138
