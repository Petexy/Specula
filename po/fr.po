#: src/pm-session.c:1063
msgid ""
"No phone found. Use Set Up Device to enter your phone's Wireless debugging "
"address."
msgstr "Aucun téléphone trouvé. Utilisez Configurer l'appareil pour saisir l'adresse de débogage sans fil de votre téléphone."
