msgstr "Redimensionnez la fenêtre librement au lieu de conserver le rapport d'aspect du téléphone."

#: src/pm-settings-dialog.c:148
msgid "Input"
msgstr "Saisie"

#: src/pm-settings-dialog.c:150
msgid "Mouse"
msgstr "Souris"

#: src/pm-settings-dialog.c:150
