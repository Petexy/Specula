#: src/pm-session.c:793
msgid ""
"Could not find scrcpy-server. Install scrcpy or set PM_SERVER_JAR to the "
"server path."
msgstr ""
"Não foi possível encontrar o scrcpy-server. Instale o scrcpy ou defina "
"PM_SERVER_JAR como o caminho do servidor."

#: src/pm-session.c:800
msgid ""
"Could not determine scrcpy-server version. Install scrcpy or set "
"PM_SCRCPY_VERSION to match your server."
msgstr ""
"Não foi possível determinar a versão do scrcpy-server. Instale o scrcpy ou "
"defina PM_SCRCPY_VERSION para corresponder ao seu servidor."

#: src/pm-session.c:858
msgid "Connecting with adb…"
msgstr "Conectando com adb…"

#: src/pm-session.c:866
msgid "Installing mirror server…"
msgstr "Instalando o servidor de espelhamento…"

#: src/pm-session.c:872
msgid "Opening mirror socket…"
msgstr "Abrindo o socket de espelhamento…"

#: src/pm-session.c:878
msgid "Starting mirror server…"
msgstr "Iniciando o servidor de espelhamento…"

#: src/pm-session.c:885
msgid "Connecting video stream…"
msgstr "Conectando o fluxo de vídeo…"

#: src/pm-session.c:896
msgid "Connecting audio stream…"
msgstr "Conectando o fluxo de áudio…"

#: src/pm-session.c:903
