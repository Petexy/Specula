msgid "Phone Mirror"
msgstr "Espelhamento do telefone"

#: src/pm-window.c:1152
msgid "Press Connect to find your phone automatically."
msgstr "Pressione Conectar para encontrar seu telefone automaticamente."

#: src/pm-window.c:1160
msgid "Searching…"
msgstr "Procurando…"

#: src/pm-window.c:1162
msgid "Looking for your phone on the local network."
msgstr "Procurando seu telefone na rede local."

#: src/pm-window.c:1170
msgid "Connecting…"
msgstr "Conectando…"

#: src/pm-window.c:1172
msgid "Starting the mirror server on your device."
msgstr "Iniciando o servidor de espelhamento no seu dispositivo."

#: src/pm-window.c:1192
msgid "Connection failed"
msgstr "Falha na conexão"

#: src/pm-window.c:1194
msgid "Could not reach the device."
msgstr "Não foi possível acessar o dispositivo."

