#: src/pm-session.c:1229
msgid ""
"No phone found. Use Set Up Device to enter your phone's Wireless debugging "
"address."
msgstr ""
"Nenhum telefone encontrado. Use Configurar dispositivo para inserir o "
"endereço de depuração sem fio do seu telefone."

#~ msgid "IP address"
#~ msgstr "Endereço IP"
