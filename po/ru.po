#: src/pm-application.c:59 src/pm-window.c:1060 src/pm-window.c:1068
#: src/pm-window.c:3856 src/pm-window.c:3875
msgid "Phone Mirror"
msgstr "Зеркало телефона"

#: src/pm-window.c:1070
msgid "Press Connect to find your phone automatically."
msgstr "Нажмите «Подключить», чтобы найти телефон автоматически."

#: src/pm-window.c:1078
msgid "Searching…"
msgstr "Поиск…"

#: src/pm-window.c:1080
msgid "Looking for your phone on the local network."
msgstr "Поиск телефона в локальной сети."

#: src/pm-window.c:1088
msgid "Connecting…"
msgstr "Подключение…"

#: src/pm-window.c:1090
msgid "Starting the mirror server on your device."
msgstr "Запуск сервера зеркалирования на устройстве."

#: src/pm-window.c:1110
msgid "Connection failed"
msgstr "Не удалось подключиться"

#: src/pm-window.c:1112
msgid "Could not reach the device."
msgstr "Не удалось связаться с устройством."

#: src/pm-window.c:1651 src/pm-window.c:1664 src/pm-connect-dialog.c:79
msgid "Lockscreen PIN"
msgstr "PIN экрана блокировки"

#: src/pm-window.c:1658 src/pm-connect-dialog.c:72
msgid "Auto-unlock"
msgstr "Автоматическая разблокировка"

#: src/pm-window.c:1660
msgid ""
"Stored encrypted on this computer, tied to this phone, and used to unlock it "
"automatically when it connects."
msgstr "Хранится в зашифрованном виде на этом компьютере, привязан к этому телефону и используется для его автоматической разблокировки при подключении."

#: src/pm-window.c:1673
msgid "Save"
msgstr "Сохранить"

#: src/pm-window.c:1676
msgid "Remove"
msgstr "Удалить"

#: src/pm-window.c:1804
msgid "Network & internet"
msgstr "Сеть и Интернет"

#: src/pm-window.c:1804
msgid "Wi-Fi, SIM, hotspot"
msgstr "Wi-Fi, SIM, точка доступа"

#: src/pm-window.c:1805
msgid "Connected devices"
msgstr "Подключённые устройства"

#: src/pm-window.c:1805
