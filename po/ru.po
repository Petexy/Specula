msgstr "Использовать беспроводную отладку"

#: src/pm-window.c:3114
msgid "Current Wi-Fi network"
msgstr "Текущая сеть Wi-Fi"

#: src/pm-window.c:3115
msgid "Wi-Fi network"
msgstr "Сеть Wi-Fi"

#: src/pm-window.c:3115
msgid "Same network as Linux"
msgstr "Та же сеть, что и Linux"

#: src/pm-window.c:3116
msgid "Android device"
msgstr "Устройство Android"

#: src/pm-window.c:3160
msgid "Allow wireless debugging?"
msgstr "Разрешить беспроводную отладку?"

#: src/pm-window.c:3161
msgid "Allow on this Wi-Fi network"
msgstr "Разрешить в этой сети Wi-Fi"

#: src/pm-window.c:3162
msgid "Allow"
msgstr "Разрешить"

#: src/pm-window.c:3177
msgid "Pair device with code"
msgstr "Сопряжение устройства по коду"

#: src/pm-window.c:3177
msgid "Shows code and address"
msgstr "Показывает код и адрес"

#: src/pm-window.c:3178
msgid "IP address & port"
msgstr "IP-адрес и порт"

