#: src/pm-window.c:2219
msgid "Photos"
msgstr "Фото"

#: src/pm-window.c:2220
msgid "Camera"
msgstr "Камера"

#: src/pm-window.c:2221 src/pm-window.c:2818 src/pm-window.c:2850
#: src/pm-window.c:2957 src/pm-settings-dialog.c:76
msgid "Settings"
msgstr "Настройки"

#: src/pm-window.c:2222
msgid "Files"
msgstr "Файлы"

#: src/pm-window.c:2245
msgid "Search your phone"
msgstr "Поиск по телефону"

#: src/pm-window.c:2623
msgid "Cancel"
msgstr "Отмена"

#: src/pm-window.c:2902
#, c-format
msgid "Tap %d of 7"
msgstr "Нажатие %d из 7"

#: src/pm-window.c:2927
msgid "You are now a developer!"
msgstr "Теперь вы разработчик!"

#: src/pm-window.c:3007
msgid "Allow USB debugging?"
msgstr "Разрешить отладку по USB?"

#: src/pm-window.c:3008
msgid "Computer RSA key fingerprint"
msgstr "Отпечаток ключа RSA компьютера"

#: src/pm-window.c:3009
msgid "OK"
msgstr "ОК"

#: src/pm-window.c:3023 src/pm-window.c:3085
msgid "Use wireless debugging"
msgstr "Использовать беспроводную отладку"

#: src/pm-window.c:3023
msgid "Current Wi-Fi network"
msgstr "Текущая сеть Wi-Fi"

#: src/pm-window.c:3024
msgid "Wi-Fi network"
msgstr "Сеть Wi-Fi"

#: src/pm-window.c:3024
msgid "Same network as Linux"
msgstr "Та же сеть, что и Linux"

#: src/pm-window.c:3025
msgid "Android device"
msgstr "Устройство Android"

#: src/pm-window.c:3069
msgid "Allow wireless debugging?"
msgstr "Разрешить беспроводную отладку?"

#: src/pm-window.c:3070
msgid "Allow on this Wi-Fi network"
msgstr "Разрешить в этой сети Wi-Fi"

#: src/pm-window.c:3071
msgid "Allow"
msgstr "Разрешить"

#: src/pm-window.c:3086
msgid "Pair device with code"
msgstr "Сопряжение устройства по коду"

#: src/pm-window.c:3086
msgid "Shows code and address"
msgstr "Показывает код и адрес"

#: src/pm-window.c:3087
msgid "IP address & port"
msgstr "IP-адрес и порт"

#: src/pm-window.c:3090 src/pm-window.c:3282 src/pm-connect-dialog.c:246
msgid "Pairing code"
msgstr "Код сопряжения"

#: src/pm-window.c:3091
msgid "Pairing address"
msgstr "Адрес сопряжения"

#: src/pm-window.c:3092
msgid "Keep this screen open"
msgstr "Не закрывайте этот экран"

#: src/pm-window.c:3092
msgid "Code expires soon"
msgstr "Срок действия кода скоро истечёт"

#: src/pm-window.c:3110
msgid "Pair device"
msgstr "Сопряжение устройства"

#: src/pm-window.c:3246 src/pm-connect-dialog.c:257
msgid "Set up device"
msgstr "Настроить устройство"

#: src/pm-window.c:3257 src/pm-connect-dialog.c:238
msgid "Pairing"
msgstr "Сопряжение"

#: src/pm-window.c:3267
msgid "Android 11+: Pair device with code."
msgstr "Android 11+: выполните сопряжение устройства по коду."

#: src/pm-window.c:3279 src/pm-connect-dialog.c:244
msgid "Pairing address (ip:port)"
msgstr "Адрес сопряжения (ip:порт)"

#: src/pm-window.c:3296 src/pm-connect-dialog.c:254
msgid "Pair & Connect"
msgstr "Сопрячь и подключить"

#: src/pm-window.c:3537
msgid "Go to Home"
msgstr "Перейти на главный экран"

#: src/pm-window.c:3538 src/pm-window.c:3746
msgid "Continue"
msgstr "Продолжить"

#: src/pm-window.c:3541
msgid "First Time Setup"
msgstr "Первоначальная настройка"

#: src/pm-window.c:3608
msgid "Welcome to Phone Mirror"
msgstr "Добро пожаловать в Зеркало телефона"

#: src/pm-window.c:3609
msgid ""
"We will help you prepare your Android phone. Keep your phone nearby and "
"connect it to the same Wi-Fi network as this computer."
msgstr "Мы поможем вам подготовить ваш телефон Android. Держите телефон поблизости и подключите его к той же сети Wi-Fi, что и этот компьютер."

#: src/pm-window.c:3612
msgid "Open Settings"
msgstr "Открыть настройки"

#: src/pm-window.c:3613
msgid "Unlock your Android phone. Find the Settings app and open it."
msgstr "Разблокируйте телефон Android. Найдите приложение «Настройки» и откройте его."

#: src/pm-window.c:3616
msgid "Find About phone"
msgstr "Найдите «О телефоне»"

#: src/pm-window.c:3617
msgid ""
"In Settings, scroll toward the bottom. Tap About phone. On some phones, open "
"System first, then tap About phone."
msgstr "В настройках прокрутите вниз. Нажмите «О телефоне». На некоторых телефонах сначала откройте «Система», затем нажмите «О телефоне»."

#: src/pm-window.c:3620
msgid "Turn on Developer options"
msgstr "Включите параметры разработчика"

#: src/pm-window.c:3621
msgid ""
"Find Build number. Tap Build number seven times. If Android asks for your "
"PIN, enter it. Stop when the phone says you are now a developer."
msgstr "Найдите «Номер сборки». Нажмите «Номер сборки» семь раз. Если Android запросит PIN-код, введите его. Остановитесь, когда телефон сообщит, что вы стали разработчиком."

#: src/pm-window.c:3624
msgid "Turn on USB debugging"
msgstr "Включите отладку по USB"

#: src/pm-window.c:3625
msgid ""
"Go back to Settings. Open Developer options. On some phones, open System "
"first, then turn on USB debugging. If Android asks, tap OK."
msgstr "Вернитесь в настройки. Откройте параметры разработчика. На некоторых телефонах сначала откройте «Система», затем включите отладку по USB. Если Android спросит, нажмите OK."

#: src/pm-window.c:3628
msgid "Turn on Wireless debugging"
msgstr "Включите беспроводную отладку"

#: src/pm-window.c:3629
msgid ""
"Stay in Developer options. Turn on Wireless debugging. Keep your phone and "
"this computer on the same network. If Android asks, tap Allow."
msgstr "Оставайтесь в параметрах разработчика. Включите беспроводную отладку. Держите телефон и этот компьютер в одной сети. Если Android спросит, нажмите «Разрешить»."

#: src/pm-window.c:3632
msgid "Get the pairing code"
msgstr "Получите код сопряжения"

#: src/pm-window.c:3633
msgid ""
"Tap Wireless debugging, then Pair device with pairing code. Leave that "
"screen open. On the home page, choose Set Up Device, enter the pairing "
"address and code, then choose Pair & Connect."
msgstr "Нажмите «Беспроводная отладка», затем «Сопряжение устройства по коду». Не закрывайте этот экран. На главной странице выберите «Настроить устройство», введите адрес и код сопряжения, затем выберите «Сопрячь и подключить»."

#: src/pm-window.c:3647
msgid "Welcome"
msgstr "Добро пожаловать"

#: src/pm-window.c:3648
#, c-format
msgid "Step %u of %u"
msgstr "Шаг %u из %u"

#: src/pm-window.c:3741
msgid "Back"
msgstr "Назад"

#: src/pm-window.c:3781
msgid "_Disconnect"
msgstr "Отключить (_D)"

#: src/pm-window.c:3782
msgid "_Lockscreen PIN…"
msgstr "PIN экрана блокировки (_L)…"

#: src/pm-window.c:3783
msgid "_First Time Setup"
msgstr "Первоначальная настройка (_F)"

#: src/pm-window.c:3789
msgid "_Manual Connection…"
msgstr "Ручное подключение (_M)…"

#: src/pm-window.c:3790
msgid "_Set Up Device…"
msgstr "Настроить устройство (_S)…"

#: src/pm-window.c:3796
msgid "_Settings"
msgstr "Настройки (_S)"

#: src/pm-window.c:3797
msgid "_About Phone Mirror"
msgstr "О приложении Зеркало телефона (_A)"

#: src/pm-window.c:3802
msgid "_Quit"
msgstr "Выйти (_Q)"

#: src/pm-window.c:3886
msgid "Keep controls visible"
msgstr "Не скрывать элементы управления"

#: src/pm-window.c:3901
msgid "Press Connect to look for your paired device."
msgstr "Нажмите «Подключить», чтобы найти сопряжённое устройство."

#: src/pm-window.c:3906
msgid "Connect"
msgstr "Подключить"

#: src/pm-window.c:3913
msgid "Set Up Device…"
msgstr "Настроить устройство…"

#: src/pm-connect-dialog.c:74
msgid ""
"OPTIONAL. Stored encrypted on this computer, keyed to the phone, and used to "
"unlock its lockscreen automatically on connect. Otherwise, the app will show "
"a black screen during unlocking phone."
msgstr "НЕОБЯЗАТЕЛЬНО. Хранится в зашифрованном виде на этом компьютере, привязан к телефону и используется для автоматической разблокировки его экрана блокировки при подключении. В противном случае во время разблокировки телефона приложение покажет чёрный экран."

#: src/pm-connect-dialog.c:104
msgid "Enter the device IP address"
msgstr "Введите IP-адрес устройства"

#: src/pm-connect-dialog.c:176
msgid "Enter pairing address (ip:port) and code"
msgstr "Введите адрес сопряжения (ip:порт) и код"

#: src/pm-connect-dialog.c:185
msgid "Invalid pairing port"
msgstr "Недопустимый порт сопряжения"

#: src/pm-connect-dialog.c:193
msgid "Pairing…"
msgstr "Сопряжение…"

#: src/pm-connect-dialog.c:240
msgid "Android 11+: enable Wireless debugging → Pair device with code."
msgstr "Android 11+: включите беспроводную отладку → Сопряжение устройства по коду."

#: src/pm-connect-dialog.c:266
msgid "Connection"
msgstr "Подключение"

#: src/pm-connect-dialog.c:268
msgid ""
"Enter the Wi-Fi debugging address only if automatic discovery cannot find "
"the phone."
msgstr "Введите адрес отладки по Wi-Fi только если автоматическое обнаружение не находит телефон."

#: src/pm-connect-dialog.c:271
msgid "IP address"
msgstr "IP-адрес"

#: src/pm-connect-dialog.c:273
msgid "Port (default 5555)"
msgstr "Порт (по умолчанию 5555)"

#: src/pm-connect-dialog.c:283
msgid "Connect manually"
msgstr "Подключиться вручную"

#: src/pm-connect-dialog.c:296
msgid "Manual connection"
msgstr "Ручное подключение"

#: src/pm-settings-dialog.c:86
msgid "Display"
msgstr "Экран"

#: src/pm-settings-dialog.c:88
msgid "Mirror"
msgstr "Зеркало"

#: src/pm-settings-dialog.c:88
msgid "Virtual"
msgstr "Виртуальный"

#: src/pm-settings-dialog.c:91
msgid "Display mode"
msgstr "Режим экрана"

#: src/pm-settings-dialog.c:93
msgid ""
"Mirror the phone's screen, or run a separate virtual display on the device."
msgstr "Зеркалируйте экран телефона или запустите отдельный виртуальный экран на устройстве."

#: src/pm-settings-dialog.c:101
msgid "Width"
msgstr "Ширина"

#: src/pm-settings-dialog.c:103
msgid "Virtual display width in pixels."
msgstr "Ширина виртуального экрана в пикселях."

#: src/pm-settings-dialog.c:107
msgid "Height"
msgstr "Высота"

#: src/pm-settings-dialog.c:109
msgid "Virtual display height in pixels."
msgstr "Высота виртуального экрана в пикселях."

#: src/pm-settings-dialog.c:113
msgid "Density (DPI)"
msgstr "Плотность (DPI)"

#: src/pm-settings-dialog.c:115
msgid "Pixel density of the virtual display."
msgstr "Плотность пикселей виртуального экрана."

#: src/pm-settings-dialog.c:122
msgid "Video bitrate (Mbps)"
msgstr "Битрейт видео (Мбит/с)"

#: src/pm-settings-dialog.c:124
msgid "Lower it to save bandwidth. Reconnects to apply."
msgstr "Уменьшите его, чтобы сэкономить пропускную способность. Применяется при повторном подключении."

#: src/pm-settings-dialog.c:132
msgid "Turn off phone screen"
msgstr "Выключить экран телефона"

#: src/pm-settings-dialog.c:134
msgid ""
"Dark the phone's panel to save battery once you unlock it. Reconnects to "
"apply."
msgstr "Затемните панель телефона, чтобы экономить заряд после разблокировки. Применяется при повторном подключении."

#: src/pm-settings-dialog.c:138
msgid "Window"
msgstr "Окно"

#: src/pm-settings-dialog.c:142
msgid "Free resize"
msgstr "Свободное изменение размера"

#: src/pm-settings-dialog.c:144
msgid "Resize the window freely instead of keeping the phone's aspect ratio."
msgstr "Изменяйте размер окна свободно, не сохраняя соотношение сторон телефона."

#: src/pm-settings-dialog.c:148
msgid "Input"
msgstr "Ввод"

#: src/pm-settings-dialog.c:150
msgid "Mouse"
msgstr "Мышь"

#: src/pm-settings-dialog.c:150
msgid "Touch"
msgstr "Касание"

#: src/pm-settings-dialog.c:153
msgid "Pointer input"
msgstr "Ввод указателем"

#: src/pm-settings-dialog.c:155
msgid "How mouse input is sent to the phone."
msgstr "Как ввод мышью передаётся на телефон."

#: src/pm-settings-dialog.c:161
msgid "Audio"
msgstr "Звук"

#: src/pm-settings-dialog.c:165
msgid "Play phone audio"
msgstr "Воспроизводить звук телефона"

#: src/pm-settings-dialog.c:167
msgid "Route the phone's sound to this computer. Reconnects to apply."
msgstr "Перенаправьте звук телефона на этот компьютер. Применяется при повторном подключении."

#: src/pm-session.c:186
msgid "Mirroring a connected phone"
msgstr "Зеркалирование подключённого телефона"

#: src/pm-session.c:371
#, c-format
msgid "scrcpy-server exited with status %d"
msgstr "scrcpy-server завершился с кодом %d"

#: src/pm-session.c:399
#, c-format
msgid "timed out waiting for scrcpy-server socket%s%s"
msgstr "истекло время ожидания сокета scrcpy-server%s%s"

#: src/pm-session.c:646
msgid "Connecting to device…"
msgstr "Подключение к устройству…"

#: src/pm-session.c:653
msgid ""
"Could not find scrcpy-server. Install scrcpy or set PM_SERVER_JAR to the "
"server path."
msgstr "Не удалось найти scrcpy-server. Установите scrcpy или укажите путь к серверу в PM_SERVER_JAR."

#: src/pm-session.c:660
msgid ""
"Could not determine scrcpy-server version. Install scrcpy or set "
"PM_SCRCPY_VERSION to match your server."
msgstr "Не удалось определить версию scrcpy-server. Установите scrcpy или укажите в PM_SCRCPY_VERSION версию вашего сервера."

#: src/pm-session.c:718
msgid "Connecting with adb…"
msgstr "Подключение через adb…"

#: src/pm-session.c:734
msgid "Installing mirror server…"
msgstr "Установка сервера зеркалирования…"

#: src/pm-session.c:740
msgid "Opening mirror socket…"
msgstr "Открытие сокета зеркалирования…"

#: src/pm-session.c:746
msgid "Starting mirror server…"
msgstr "Запуск сервера зеркалирования…"

#: src/pm-session.c:753
msgid "Connecting video stream…"
msgstr "Подключение видеопотока…"

#: src/pm-session.c:764
msgid "Connecting audio stream…"
msgstr "Подключение аудиопотока…"

#: src/pm-session.c:771
msgid "Connecting controls…"
msgstr "Подключение управления…"

#: src/pm-session.c:782
msgid "Reading video stream…"
msgstr "Чтение видеопотока…"

#: src/pm-session.c:929
#, c-format
msgid "%s failed: %s%s"
msgstr "%s завершилось ошибкой: %s%s"

#: src/pm-session.c:931
msgid "connection failed"
msgstr "не удалось подключиться"

#: src/pm-session.c:994
msgid "Found device — starting mirror server…"
msgstr "Устройство найдено — запуск сервера зеркалирования…"

#: src/pm-session.c:1063
msgid ""
