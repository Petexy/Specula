#: src/pm-session.c:786
msgid "Connecting to device…"
msgstr "Verbindung zum Gerät wird hergestellt…"

#: src/pm-session.c:793
msgid ""
"Could not find scrcpy-server. Install scrcpy or set PM_SERVER_JAR to the "
"server path."
msgstr ""
"scrcpy-server konnte nicht gefunden werden. Installieren Sie scrcpy oder "
"setzen Sie PM_SERVER_JAR auf den Serverpfad."

#: src/pm-session.c:800
msgid ""
"Could not determine scrcpy-server version. Install scrcpy or set "
"PM_SCRCPY_VERSION to match your server."
msgstr ""
"Die Version von scrcpy-server konnte nicht ermittelt werden. Installieren "
"Sie scrcpy oder setzen Sie PM_SCRCPY_VERSION passend zu Ihrem Server."

#: src/pm-session.c:858
msgid "Connecting with adb…"
msgstr "Verbindung über adb…"

#: src/pm-session.c:866
msgid "Installing mirror server…"
msgstr "Spiegelungsserver wird installiert…"

#: src/pm-session.c:872
msgid "Opening mirror socket…"
msgstr "Spiegelungs-Socket wird geöffnet…"

#: src/pm-session.c:878
msgid "Starting mirror server…"
msgstr "Spiegelungsserver wird gestartet…"

#: src/pm-session.c:885
msgid "Connecting video stream…"
msgstr "Videostream wird verbunden…"

#: src/pm-session.c:896
msgid "Connecting audio stream…"
