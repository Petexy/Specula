msgstr "Verbindung fehlgeschlagen"

#: src/pm-session.c:994
msgid "Found device — starting mirror server…"
msgstr "Gerät gefunden – Spiegelungsserver wird gestartet…"

#: src/pm-session.c:1063
msgid ""
"No phone found. Use Set Up Device to enter your phone's Wireless debugging "
"address."
msgstr "Kein Telefon gefunden. Verwenden Sie Gerät einrichten, um die Adresse für drahtloses Debugging Ihres Telefons einzugeben."
