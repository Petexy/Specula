msgstr "Falsche PIN"

#: src/pm-window.c:1429
msgid "Unlock Phone"
msgstr "Telefon entsperren"

#: src/pm-window.c:1430
msgid "Try again."
msgstr "Versuchen Sie es erneut."

#: src/pm-window.c:1430
msgid "Enter your PIN."
msgstr "Geben Sie Ihre PIN ein."

#: src/pm-window.c:1434
msgid "PIN"
msgstr "PIN"

