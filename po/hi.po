#: src/pm-application.c:59 src/pm-window.c:1163 src/pm-window.c:1171
#: src/pm-window.c:4282 src/pm-window.c:4301
msgid "Phone Mirror"
msgstr "फ़ोन मिरर"

#: src/pm-window.c:1154 src/pm-window.c:1214 src/pm-session.c:1229
msgid "No phone found"
msgstr "कोई फ़ोन नहीं मिला"

#: src/pm-window.c:1173
msgid "Press Connect to find your phone automatically."
msgstr "अपना फ़ोन स्वचालित रूप से ढूँढने के लिए कनेक्ट दबाएँ।"

#: src/pm-window.c:1181
msgid "Searching…"
msgstr "खोज रहा है…"

#: src/pm-window.c:1183
msgid "Looking for your phone on the local network."
msgstr "स्थानीय नेटवर्क पर आपका फ़ोन खोजा जा रहा है।"

#: src/pm-window.c:1191
msgid "Connecting…"
msgstr "कनेक्ट हो रहा है…"

#: src/pm-window.c:1193
msgid "Starting the mirror server on your device."
msgstr "आपके डिवाइस पर मिरर सर्वर शुरू किया जा रहा है।"

#: src/pm-window.c:1214
msgid "Connection failed"
msgstr "कनेक्शन विफल"

#: src/pm-window.c:1217
msgid ""
"Make sure Wireless ADB is turned on on your phone. Android turns it off "
"every time the phone loses its Wi-Fi connection."
msgstr ""
"सुनिश्चित करें कि आपके फ़ोन पर वायरलेस ADB चालू है। जब भी फ़ोन का Wi-Fi "
"कनेक्शन टूटता है, Android इसे बंद कर देता है।"

#: src/pm-window.c:1219
msgid "Could not reach the device."
msgstr "डिवाइस तक नहीं पहुँचा जा सका।"

#: src/pm-window.c:1454 src/pm-window.c:1522
msgid "Incorrect PIN"
msgstr "गलत पिन"

#: src/pm-window.c:1454
msgid "Unlock Phone"
msgstr "फ़ोन अनलॉक करें"

#: src/pm-window.c:1455
msgid "Try again."
msgstr "पुनः प्रयास करें।"

#: src/pm-window.c:1455
msgid "Enter your PIN."
msgstr "अपना पिन डालें।"

#: src/pm-window.c:1459
msgid "PIN"
msgstr "पिन"

#: src/pm-window.c:1465 src/pm-window.c:3004
msgid "Cancel"
msgstr "रद्द करें"

#. Floating Unlock button: an accent pill riding over the bottom of the mirror,
#. * shown only while the phone is on its lockscreen (driven by the session's
#. * keyguard poll). Tapping it opens the one-time PIN dialog. A revealer
#. * crossfades it in/out, mirroring the auto-unlock alert above. Uses the same
#. * pill + suggested-action style as the app's other primary actions.
#: src/pm-window.c:1466 src/pm-window.c:4395
msgid "Unlock"
msgstr "अनलॉक करें"

#: src/pm-window.c:1523
msgid ""
"The saved lockscreen PIN didn't unlock your phone. Auto-unlock has stopped "
"trying so repeated wrong attempts can't lock you out of the device. Enter "
"the correct PIN to try again."
msgstr ""
"सहेजा गया लॉकस्क्रीन पिन आपके फ़ोन को अनलॉक नहीं कर सका। ऑटो-अनलॉक ने प्रयास करना बंद "
"कर दिया है ताकि बार-बार गलत प्रयास आपको डिवाइस से लॉक न कर दें। पुनः प्रयास करने के "
"लिए सही पिन दर्ज करें।"

#: src/pm-window.c:1528
msgid "Dismiss"
msgstr "खारिज करें"

#: src/pm-window.c:1529
msgid "Enter PIN"
msgstr "पिन डालें"

#: src/pm-window.c:2012 src/pm-window.c:2025 src/pm-connect-dialog.c:138
msgid "Lockscreen PIN"
msgstr "लॉकस्क्रीन पिन"

#: src/pm-window.c:2019 src/pm-connect-dialog.c:131
msgid "Auto-unlock"
msgstr "स्वचालित अनलॉक"

#: src/pm-window.c:2021
msgid ""
"Stored encrypted on this computer, tied to this phone, and used to unlock it "
"automatically when it connects."
msgstr ""
"इस कंप्यूटर पर एन्क्रिप्टेड रूप में संग्रहीत, इस फ़ोन से जुड़ा हुआ, और कनेक्ट होने पर इसे स्वचालित "
"रूप से अनलॉक करने के लिए उपयोग किया जाता है।"

#: src/pm-window.c:2034
msgid "Save"
msgstr "सहेजें"

#: src/pm-window.c:2037
msgid "Remove"
msgstr "हटाएँ"

#: src/pm-window.c:2184
msgid "Network & internet"
msgstr "नेटवर्क और इंटरनेट"

#: src/pm-window.c:2184
msgid "Wi-Fi, SIM, hotspot"
msgstr "वाई-फ़ाई, सिम, हॉटस्पॉट"

#: src/pm-window.c:2185
msgid "Connected devices"
msgstr "कनेक्टेड डिवाइस"

#: src/pm-window.c:2185
msgid "Bluetooth, pairing"
msgstr "ब्लूटूथ, पेयरिंग"

#: src/pm-window.c:2186
msgid "Apps"
msgstr "ऐप्स"

#: src/pm-window.c:2186
msgid "Permissions and defaults"
msgstr "अनुमतियाँ और डिफ़ॉल्ट"

#: src/pm-window.c:2187
msgid "Notifications"
msgstr "सूचनाएँ"

#: src/pm-window.c:2187
msgid "History and conversations"
msgstr "इतिहास और बातचीत"

#: src/pm-window.c:2188
msgid "Battery"
msgstr "बैटरी"

#: src/pm-window.c:2188
msgid "87%, until 10:30 PM"
msgstr "87%, रात 10:30 बजे तक"

#: src/pm-window.c:2189
msgid "System"
msgstr "सिस्टम"

#: src/pm-window.c:2189
msgid "Languages, gestures, time"
msgstr "भाषाएँ, जेस्चर, समय"

#: src/pm-window.c:2190 src/pm-window.c:3241 src/pm-window.c:3274
#: src/pm-window.c:3351
msgid "About phone"
msgstr "फ़ोन के बारे में"

#: src/pm-window.c:2190
msgid "Model, Android version"
msgstr "मॉडल, Android संस्करण"

#: src/pm-window.c:2191 src/pm-window.c:3364 src/pm-window.c:3421
