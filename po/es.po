msgstr "Pulse Conectar para buscar su dispositivo vinculado."

#: src/pm-window.c:4304
msgid "Connect"
msgstr "Conectar"

#: src/pm-window.c:4311
msgid "Set Up Device…"
msgstr "Configurar dispositivo…"

#: src/pm-window.c:4336
msgid "Unlocking your phone…"
msgstr "Desbloqueando su teléfono…"

#: src/pm-connect-dialog.c:133
msgid ""
"Optional. Unlocks your phone automatically when it connects. Otherwise, the "
"app will show a black screen while you unlock your phone."
msgstr ""
"Opcional. Desbloquea el teléfono automáticamente al conectarse. De lo "
"contrario, la aplicación mostrará una pantalla negra mientras desbloqueas el "
"teléfono."

#: src/pm-connect-dialog.c:166
msgid "Enter the device IP address"
msgstr "Introduzca la dirección IP del dispositivo"

#: src/pm-connect-dialog.c:240
msgid "Enter pairing address (ip:port) and code"
msgstr "Introduzca la dirección de vinculación (ip:puerto) y el código"

#: src/pm-connect-dialog.c:249
msgid "Invalid pairing port"
msgstr "Puerto de vinculación no válido"

#: src/pm-connect-dialog.c:257
msgid "Pairing…"
msgstr "Vinculando…"

#: src/pm-connect-dialog.c:304
msgid "Enable Wireless debugging → Pair device with code."
msgstr "Active la depuración inalámbrica → Vincular dispositivo con código."

#: src/pm-connect-dialog.c:330
msgid "Connection"
msgstr "Conexión"

#: src/pm-connect-dialog.c:332
msgid ""
"Enter the Wi-Fi debugging address only if automatic discovery cannot find "
"the phone."
msgstr ""
"Introduzca la dirección de depuración Wi-Fi solo si la detección automática "
"no puede encontrar el teléfono."

#: src/pm-connect-dialog.c:335
msgid "IP address or ip:port"
msgstr "Dirección IP o ip:port"

#: src/pm-connect-dialog.c:337
msgid "Port (default 5555)"
msgstr "Puerto (predeterminado 5555)"

