msgstr "Anchura de la pantalla virtual en píxeles."

#: src/pm-settings-dialog.c:107
msgid "Height"
msgstr "Altura"

#: src/pm-settings-dialog.c:109
msgid "Virtual display height in pixels."
msgstr "Altura de la pantalla virtual en píxeles."

#: src/pm-settings-dialog.c:113
msgid "Density (DPI)"
msgstr "Densidad (PPP)"

#: src/pm-settings-dialog.c:115
msgid "Pixel density of the virtual display."
msgstr "Densidad de píxeles de la pantalla virtual."

#: src/pm-settings-dialog.c:122
msgid "Video bitrate (Mbps)"
msgstr "Tasa de bits de vídeo (Mbps)"

#: src/pm-settings-dialog.c:124
msgid "Lower it to save bandwidth. Reconnects to apply."
msgstr "Redúzcala para ahorrar ancho de banda. Se reconecta para aplicar."

#: src/pm-settings-dialog.c:132
msgid "Turn off phone screen"
msgstr "Apagar la pantalla del teléfono"

#: src/pm-settings-dialog.c:134
msgid ""
"Dark the phone's panel to save battery once you unlock it. Reconnects to "
"apply."
msgstr "Oscurezca el panel del teléfono para ahorrar batería una vez que lo desbloquee. Se reconecta para aplicar."

#: src/pm-settings-dialog.c:138
msgid "Window"
msgstr "Ventana"

#: src/pm-settings-dialog.c:142
msgid "Free resize"
msgstr "Cambio de tamaño libre"

#: src/pm-settings-dialog.c:144
msgid "Resize the window freely instead of keeping the phone's aspect ratio."
msgstr "Cambie el tamaño de la ventana libremente en lugar de mantener la relación de aspecto del teléfono."

#: src/pm-settings-dialog.c:148
msgid "Input"
msgstr "Entrada"

#: src/pm-settings-dialog.c:150
msgid "Mouse"
msgstr "Ratón"

#: src/pm-settings-dialog.c:150
msgid "Touch"
msgstr "Táctil"

#: src/pm-settings-dialog.c:153
msgid "Pointer input"
msgstr "Entrada del puntero"

#: src/pm-settings-dialog.c:155
msgid "How mouse input is sent to the phone."
msgstr "Cómo se envía la entrada del ratón al teléfono."

#: src/pm-settings-dialog.c:161
msgid "Audio"
msgstr "Audio"

#: src/pm-settings-dialog.c:165
msgid "Play phone audio"
msgstr "Reproducir el audio del teléfono"

#: src/pm-settings-dialog.c:167
msgid "Route the phone's sound to this computer. Reconnects to apply."
msgstr "Dirija el sonido del teléfono a este equipo. Se reconecta para aplicar."

#: src/pm-session.c:186
msgid "Mirroring a connected phone"
msgstr "Reflejando un teléfono conectado"

#: src/pm-session.c:371
#, c-format
msgid "scrcpy-server exited with status %d"
msgstr "scrcpy-server finalizó con el estado %d"

#: src/pm-session.c:399
#, c-format
msgid "timed out waiting for scrcpy-server socket%s%s"
msgstr "tiempo de espera agotado para el socket de scrcpy-server%s%s"

#: src/pm-session.c:646
msgid "Connecting to device…"
msgstr "Conectando con el dispositivo…"

#: src/pm-session.c:653
msgid ""
"Could not find scrcpy-server. Install scrcpy or set PM_SERVER_JAR to the "
"server path."
msgstr "No se pudo encontrar scrcpy-server. Instale scrcpy o establezca PM_SERVER_JAR en la ruta del servidor."

#: src/pm-session.c:660
msgid ""
"Could not determine scrcpy-server version. Install scrcpy or set "
"PM_SCRCPY_VERSION to match your server."
msgstr "No se pudo determinar la versión de scrcpy-server. Instale scrcpy o establezca PM_SCRCPY_VERSION para que coincida con su servidor."

#: src/pm-session.c:718
msgid "Connecting with adb…"
msgstr "Conectando con adb…"

#: src/pm-session.c:734
msgid "Installing mirror server…"
msgstr "Instalando el servidor de espejo…"

#: src/pm-session.c:740
msgid "Opening mirror socket…"
msgstr "Abriendo el socket de espejo…"

#: src/pm-session.c:746
msgid "Starting mirror server…"
msgstr "Iniciando el servidor de espejo…"

#: src/pm-session.c:753
msgid "Connecting video stream…"
msgstr "Conectando el flujo de vídeo…"

#: src/pm-session.c:764
msgid "Connecting audio stream…"
msgstr "Conectando el flujo de audio…"

#: src/pm-session.c:771
msgid "Connecting controls…"
msgstr "Conectando los controles…"

#: src/pm-session.c:782
msgid "Reading video stream…"
msgstr "Leyendo el flujo de vídeo…"

#: src/pm-session.c:929
#, c-format
msgid "%s failed: %s%s"
msgstr "%s falló: %s%s"

#: src/pm-session.c:931
msgid "connection failed"
msgstr "error de conexión"

#: src/pm-session.c:994
msgid "Found device — starting mirror server…"
msgstr "Dispositivo encontrado: iniciando el servidor de espejo…"

#: src/pm-session.c:1063
msgid ""
"No phone found. Use Set Up Device to enter your phone's Wireless debugging "
"address."
msgstr "No se encontró ningún teléfono. Use Configurar dispositivo para introducir la dirección de depuración inalámbrica de su teléfono."
