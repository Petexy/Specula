#: src/pm-application.c:59 src/pm-window.c:1142 src/pm-window.c:1150
#: src/pm-window.c:4252 src/pm-window.c:4271
msgid "Phone Mirror"
msgstr "Espejo del teléfono"

#: src/pm-window.c:1152
msgid "Press Connect to find your phone automatically."
msgstr "Pulse Conectar para encontrar su teléfono automáticamente."

#: src/pm-window.c:1160
msgid "Searching…"
msgstr "Buscando…"

#: src/pm-window.c:1162
msgid "Looking for your phone on the local network."
msgstr "Buscando su teléfono en la red local."

#: src/pm-window.c:1170
msgid "Connecting…"
msgstr "Conectando…"

#: src/pm-window.c:1172
msgid "Starting the mirror server on your device."
msgstr "Iniciando el servidor de espejo en su dispositivo."

#: src/pm-window.c:1192
msgid "Connection failed"
msgstr "Error de conexión"

#: src/pm-window.c:1194
msgid "Could not reach the device."
msgstr "No se pudo conectar con el dispositivo."

#: src/pm-window.c:1429 src/pm-window.c:1497
msgid "Incorrect PIN"
msgstr "PIN incorrecto"

#: src/pm-window.c:1429
msgid "Unlock Phone"
msgstr "Desbloquear teléfono"

#: src/pm-window.c:1430
msgid "Try again."
msgstr "Inténtelo de nuevo."

#: src/pm-window.c:1430
msgid "Enter your PIN."
msgstr "Introduzca su PIN."

#: src/pm-window.c:1434
msgid "PIN"
msgstr "PIN"

#: src/pm-window.c:1440 src/pm-window.c:2974
msgid "Cancel"
msgstr "Cancelar"

#. Floating Unlock button: an accent pill riding over the bottom of the mirror,
#. * shown only while the phone is on its lockscreen (driven by the session's
#. * keyguard poll). Tapping it opens the one-time PIN dialog. A revealer
#. * crossfades it in/out, mirroring the auto-unlock alert above. Uses the same
#. * pill + suggested-action style as the app's other primary actions.
#: src/pm-window.c:1441 src/pm-window.c:4357
msgid "Unlock"
msgstr "Desbloquear"

#: src/pm-window.c:1498
msgid ""
"The saved lockscreen PIN didn't unlock your phone. Auto-unlock has stopped "
"trying so repeated wrong attempts can't lock you out of the device. Enter "
"the correct PIN to try again."
msgstr ""
"El PIN de la pantalla de bloqueo guardado no desbloqueó su teléfono. El "
"desbloqueo automático ha dejado de intentarlo para que los intentos fallidos "
"repetidos no le bloqueen el acceso al dispositivo. Introduzca el PIN "
"correcto para volver a intentarlo."

#: src/pm-window.c:1503
msgid "Dismiss"
msgstr "Descartar"

#: src/pm-window.c:1504
msgid "Enter PIN"
msgstr "Introducir PIN"

#: src/pm-window.c:1993 src/pm-window.c:2006 src/pm-connect-dialog.c:138
msgid "Lockscreen PIN"
msgstr "PIN de pantalla de bloqueo"

#: src/pm-window.c:2000 src/pm-connect-dialog.c:131
msgid "Auto-unlock"
msgstr "Desbloqueo automático"

#: src/pm-window.c:2002
msgid ""
"Stored encrypted on this computer, tied to this phone, and used to unlock it "
"automatically when it connects."
msgstr ""
"Se almacena cifrado en este equipo, vinculado a este teléfono, y se usa para "
"desbloquearlo automáticamente al conectarse."

