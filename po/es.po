#: src/pm-session.c:1132
msgid ""
"No phone found. Use Set Up Device to enter your phone's Wireless debugging "
"address."
msgstr ""
"No se encontró ningún teléfono. Use Configurar dispositivo para introducir "
"la dirección de depuración inalámbrica de su teléfono."

#~ msgid "IP address"
