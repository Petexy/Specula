#: src/pm-window.c:3790
msgid "_Set Up Device…"
msgstr "_Configurar dispositivo…"

#: src/pm-window.c:3796
msgid "_Settings"
msgstr "_Configuración"

#: src/pm-window.c:3797
msgid "_About Phone Mirror"
msgstr "_Acerca de Espejo del teléfono"

#: src/pm-window.c:3802
msgid "_Quit"
msgstr "_Salir"

#: src/pm-window.c:3886
msgid "Keep controls visible"
msgstr "Mantener los controles visibles"

#: src/pm-window.c:3901
msgid "Press Connect to look for your paired device."
msgstr "Pulse Conectar para buscar su dispositivo vinculado."

#: src/pm-window.c:3906
msgid "Connect"
msgstr "Conectar"

#: src/pm-window.c:3913
msgid "Set Up Device…"
msgstr "Configurar dispositivo…"

#: src/pm-connect-dialog.c:74
msgid ""
"OPTIONAL. Stored encrypted on this computer, keyed to the phone, and used to "
"unlock its lockscreen automatically on connect. Otherwise, the app will show "
"a black screen during unlocking phone."
msgstr "OPCIONAL. Se almacena cifrado en este equipo, vinculado al teléfono, y se usa para desbloquear automáticamente su pantalla de bloqueo al conectarse. De lo contrario, la aplicación mostrará una pantalla negra mientras se desbloquea el teléfono."

#: src/pm-connect-dialog.c:104
msgid "Enter the device IP address"
msgstr "Introduzca la dirección IP del dispositivo"

#: src/pm-connect-dialog.c:176
msgid "Enter pairing address (ip:port) and code"
msgstr "Introduzca la dirección de vinculación (ip:puerto) y el código"

#: src/pm-connect-dialog.c:185
msgid "Invalid pairing port"
msgstr "Puerto de vinculación no válido"

#: src/pm-connect-dialog.c:193
msgid "Pairing…"
msgstr "Vinculando…"

#: src/pm-connect-dialog.c:240
msgid "Android 11+: enable Wireless debugging → Pair device with code."
msgstr "Android 11+: active la depuración inalámbrica → Vincular dispositivo con código."

#: src/pm-connect-dialog.c:266
msgid "Connection"
msgstr "Conexión"

#: src/pm-connect-dialog.c:268
msgid ""
"Enter the Wi-Fi debugging address only if automatic discovery cannot find "
"the phone."
msgstr "Introduzca la dirección de depuración Wi-Fi solo si la detección automática no puede encontrar el teléfono."

#: src/pm-connect-dialog.c:271
msgid "IP address"
msgstr "Dirección IP"

#: src/pm-connect-dialog.c:273
msgid "Port (default 5555)"
msgstr "Puerto (predeterminado 5555)"

#: src/pm-connect-dialog.c:283
msgid "Connect manually"
msgstr "Conectar manualmente"

#: src/pm-connect-dialog.c:296
msgid "Manual connection"
msgstr "Conexión manual"

#: src/pm-settings-dialog.c:86
msgid "Display"
msgstr "Pantalla"

#: src/pm-settings-dialog.c:88
msgid "Mirror"
msgstr "Espejo"

#: src/pm-settings-dialog.c:88
msgid "Virtual"
msgstr "Virtual"

#: src/pm-settings-dialog.c:91
msgid "Display mode"
msgstr "Modo de pantalla"

#: src/pm-settings-dialog.c:93
msgid ""
"Mirror the phone's screen, or run a separate virtual display on the device."
msgstr "Refleje la pantalla del teléfono o ejecute una pantalla virtual independiente en el dispositivo."

#: src/pm-settings-dialog.c:101
msgid "Width"
msgstr "Anchura"

#: src/pm-settings-dialog.c:103
